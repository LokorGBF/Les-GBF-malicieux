# ────────────────────────────────────────────────
# FONCTIONS DE SIMULATION
# ────────────────────────────────────────────────
def f_rhs(T, phinet, C, q_latent):
    """Calcule dT/dt."""
    return (
        phinet
        - q_latent
        + lib.P_em_atm_thermal(lib.Tatm)
        - lib.P_em_surf_thermal(T)
    ) / C


def integrate_point_temperature(
    days, lat_rad, lon_deg,
    alb_sol_daily, alb_nuages_daily,
    C_const, q_base,
    T0=288.0,
    dt_override=None,
    dev_mode=False,
):
    """
    Intègre la température pour UN SEUL point géographique.

    Changements vs version originale :
    - dt_override : permet d'utiliser un pas de temps différent de lib.dt
    - dev_mode    : utilise Euler explicite (rapide) au lieu de Newton (précis)
    - Calcul vectorisé du signe jour/nuit (np.where sur tableau de temps)
    """
    dt = dt_override if dt_override is not None else lib.dt
    N  = int(days * 24 * 3600 / dt)
    T  = np.empty(N + 1)
    T[0] = T0

    # --- Vectorisation du pré-calcul jour/nuit (supprime la boucle Python) ---
    t_vec       = np.arange(N) * dt
    days_vec    = (t_vec // 86400).astype(int) + 1
    # heure solaire approximée (on évite d'appeler f.get_time_variables en boucle)
    heure_vec   = (t_vec % 86400) / 3600.0 + lon_deg / 15.0
    cos_inc_vec = np.array([
        f.cos_incidence(lat_rad, days_vec[k], heure_vec[k]) for k in range(N)
    ])
    sign_daynight = np.where(cos_inc_vec > 0, 1.0, -1.0)
    q_latent_smoothed = gaussian_filter1d(q_base * sign_daynight, sigma=3.0, mode="wrap")

    # --- Intégration temporelle ---
    for k in range(N):
        t_sec = k * dt
        day_of_year, heure_solaire = f.get_time_variables(t_sec, lon_deg)
        jour_sim = int(t_sec // 86400) + 1

        albedo_sol    = alb_sol_daily[day_of_year]
        albedo_nuages = alb_nuages_daily[day_of_year]
        q_latent_step = q_latent_smoothed[k]

        phi_n = lib.P_inc_solar(lat_rad, jour_sim, heure_solaire, albedo_sol, albedo_nuages)

        if dev_mode:
            # Euler explicite : 1 évaluation par pas (rapide, moins précis)
            T[k + 1] = T[k] + dt * f_rhs(T[k], phi_n, C_const, q_latent_step)
        else:
            # Newton–Raphson implicite : 8 itérations (original, précis)
            X = T[k]
            for _ in range(8):
                F  = X - T[k] - dt * f_rhs(X, phi_n, C_const, q_latent_step)
                dF = 1.0 - dt * (-4.0 * lib.sigma * X**3 / C_const)
                if abs(dF) < 1e-9:
                    break
                X -= F / dF
                if abs(F) < 1e-6:
                    break
            T[k + 1] = X

    return T


def _simulate_one_point(i, j, days, dt_override, dev_mode):
    lat, lon = LAT[i], LON[j]

    albedo_mensuel_loc = monthly_albedo_sol[:, i, j]
    alb_sol_daily      = f.lisser_donnees_annuelles(albedo_mensuel_loc, sigma=15.0)

    try:
        import xarray as xr
        if isinstance(CERES_CLIM_DATA, xr.DataArray):
            lat_arr = CERES_CLIM_DATA.coords["lat"].values
            lon_arr = CERES_CLIM_DATA.coords["lon"].values
            i_lat   = np.argmin(np.abs(lat_arr - lat))
            i_lon   = np.argmin(np.abs(lon_arr - lon))
            alb_nuages_m = CERES_CLIM_DATA.isel(lat=i_lat, lon=i_lon).values
        else:
            raise TypeError
    except (ImportError, TypeError, AttributeError):
        alb_nuages_m = np.zeros(12)

    alb_nuages_daily = f.lisser_donnees_annuelles(alb_nuages_m, sigma=15.0)

    lat_idx_rzsm = min(np.abs(lat_bins_rzsm[:-1] - lat).argmin(), RZSM_GRID.shape[0] - 1)
    lon_idx_rzsm = min(np.abs(lon_bins_rzsm[:-1] - lon).argmin(), RZSM_GRID.shape[1] - 1)
    rzsm_val     = RZSM_GRID[lat_idx_rzsm, lon_idx_rzsm]
    cp_kj        = (
        f.compute_cp_from_rzsm(np.array([rzsm_val]))[0]
        if not np.isnan(rzsm_val) else f.CP_SEC
    )
    C_const   = (cp_kj * 1000.0) * f.RHO_BULK * lib.EPAISSEUR_ACTIVE
    continent = f.continent_finder(lat, lon)
    q_base    = lib.Q_LATENT_CONTINENT.get(continent, lib.Q_LATENT_CONTINENT["Océan"])
    if lat > 75:
        q_base = 0.0

    T0 = 288.15 - 30 * np.sin(np.radians(lat)) ** 2

    T_series = integrate_point_temperature(
        days, np.radians(lat), lon,
        alb_sol_daily, alb_nuages_daily,
        C_const, q_base, T0,
        dt_override=dt_override,
        dev_mode=dev_mode,
    )
    return i, j, T_series


def run_full_simulation(days, stabilize=False):
    """
    Exécute la simulation pour toute la grille et sauvegarde le résultat.

    Changement vs version originale :
    - Parallélisation via joblib.Parallel (n_jobs=-1 = tous les cœurs)
    - Les indices (i, j) sont retournés par _simulate_one_point pour
      remplir T_grid dans le bon ordre malgré l'exécution parallèle.
    """
    result_file = STABILIZED_FILE if stabilize else ONEYEAR_FILE
    if DEV_MODE:
        result_file = DEV_FILE

    NPY_DIR.mkdir(parents=True, exist_ok=True)
    dt    = DT_OVERRIDE if DEV_MODE else lib.dt
    N_steps = int(days * 24 * 3600 / dt) + 1

    sim_type = "DEV (rapide)" if DEV_MODE else ("stabilisée (2 ans)" if stabilize else "complète (1 an)")
    print(f"\nLancement de la simulation globale {sim_type}...")
    print(f"  Points : {NLAT}×{NLON}={NLAT*NLON} | pas de temps : {dt//3600:.1f} h | jours : {days}")

    T_grid = np.zeros((N_steps, NLAT, NLON))

    # Génère la liste de tous les (i, j) à simuler
    tasks = [(i, j) for i in range(NLAT) for j in range(NLON)]

    # Parallélisation : n_jobs=-1 utilise tous les cœurs disponibles
    results = Parallel(n_jobs=-1, prefer="threads")(
        delayed(_simulate_one_point)(i, j, days, DT_OVERRIDE if DEV_MODE else None, DEV_MODE)
        for i, j in tqdm(tasks, desc="Simulation des points")
    )

    for i, j, T_series in results:
        T_grid[:, i, j] = T_series

    if stabilize and not DEV_MODE:
        print("Extraction de la deuxième année...")
        steps_per_year = int(365 * 24 * 3600 / dt)
        T_grid = T_grid[steps_per_year:, :, :]

    print(f"Sauvegarde dans '{result_file}'...")
    np.save(result_file, T_grid)
    return T_grid


